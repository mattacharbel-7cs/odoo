<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_username" model="ir.ui.view">
        <name>res.partner.form.inherit.username</name>
        <model>res.partner</model>
        <inherit_id ref="base.view_partner_form"/>
        <arch type="xml">
            <!-- Locate the name field under the h1 title header and insert username next to it -->
            <xpath expr="//field[@name='name']/.." position="inside">
                <div class="d-flex align-items-center ms-3" style="font-size: 16px;">
                    <span class="text-muted me-2">@</span>
                    <field name="x_username" placeholder="Username" class="oe_inline" style="border-bottom: 1px dashed #ccc !important; font-weight: normal;"/>
                </div>
            </xpath>
        </arch>
    </record>
</odoo>
