<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_partner_form_inherit_username" model="ir.ui.view">
            <name>res.partner.form.inherit.username</name>
            <model>res.partner</model>
            <inherit_id ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <!-- Locate the parent of the name field and insert username inside it -->
                <xpath expr="//field[@name='name']/.." position="inside">
                    <style>
                        /* Force the username field text to render as white in both read and edit modes */
                        [name="x_studio_username"],
                        [name="x_studio_username"] input,
                        [name="x_studio_username"] span,
                        .o_field_widget[name="x_studio_username"] {
                            color: #FFFFFF !important;
                        }
                    </style>
                    <div class="d-flex align-items-center ms-3" style="font-size: 24px; font-weight: bold;">
                        <span class="text-white-50 me-2">@</span>
                        <field name="x_studio_username" placeholder="Username" class="oe_inline" style="border-bottom: 1px dashed rgba(255,255,255,0.5) !important; font-weight: bold; color: #FFFFFF !important;"/>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
