<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_username" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.username</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Insert the big @username next to the contact name.
                 Text is forced white via static/src/css/username.css (backend asset). -->
            <xpath expr="//field[@name='name']/.." position="inside">
                <div class="d-flex align-items-center ms-3 text-white" style="font-size: 24px; font-weight: bold;">
                    <span class="text-white-50 me-2">@</span>
                    <field name="x_studio_username" placeholder="Username" class="oe_inline text-white" style="border-bottom: 1px dashed rgba(255,255,255,0.5); font-weight: bold;"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
