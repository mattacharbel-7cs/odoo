<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_partner_form_inherit_username" model="ir.ui.view">
            <name>res.partner.form.inherit.username</name>
            <model>res.partner</model>
            <inherit_id ref="base.view_partner_form"/>
            <arch type="xml">
                <!-- Locate the parent of the name field and insert username inside it with larger font -->
                <xpath expr="//field[@name='name']/.." position="inside">
                    <div class="d-flex align-items-center ms-3" style="font-size: 24px; font-weight: bold;">
                        <span class="text-muted me-2">@</span>
                        <field name="x_studio_username" placeholder="Username" class="oe_inline" style="border-bottom: 1px dashed #ccc !important; font-weight: bold; color: #1B3A5C;"/>
                    </div>
                </xpath>
            </arch>
        </record>
    </data>
</odoo>
