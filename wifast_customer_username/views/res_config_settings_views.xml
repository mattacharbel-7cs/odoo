<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_wifast_customer_username" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.wifast.customer.username</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="WiFast Customer Username" string="WiFast Customer Username" name="wifast_customer_username">
                    <block title="API">
                        <setting id="wifast_customer_username_api_key"
                                 string="API Key"
                                 help="External systems must send this key in X-API-Key or Authorization: Bearer headers.">
                            <field name="wifast_customer_username_api_key"
                                   password="True"
                                   placeholder="Paste API key"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
